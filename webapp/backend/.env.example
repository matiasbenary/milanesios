# MiniMax API (https://api.minimax.chat). Endpoints internacionales (https://api.minimaxi.chat) si tu cuenta es global.
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Endpoint base. Default es el oficial chino; usa "https://api.minimaxi.chat/v1" si tu cuenta es global.
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
# Modelo de chat. Opciones: MiniMax-M2, MiniMax-Text-01, abab6.5s-chat, abab6.5-chat
MINIMAX_CHAT_MODEL=MiniMax-Text-01

PORT=3001
# Si la wiki la va a hostear nginx u otro, lo cambiás.
ALLOWED_ORIGIN=http://localhost:5173
